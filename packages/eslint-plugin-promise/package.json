{
  "name": "@mizunashi_mana/eslint-plugin-promise",
  "version": "0.0.0",
  "description": "ESLint plugin for Promise best practices (ESLint v10)",
  "license": "(Apache-2.0 OR MPL-2.0)",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint:eslint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@mizunashi_mana/eslint-config-refined": "^0.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.0",
    "jiti": "^2.6.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.0"
  }
}
