{
  "name": "@mizunashi_mana/eslint-plugin-promise",
  "version": "0.1.0",
  "description": "ESLint plugin for Promise best practices (ESLint v10)",
  "license": "(Apache-2.0 OR MPL-2.0)",
  "author": "mizunashi-mana",
  "homepage": "https://github.com/mizunashi-mana/eslint-config-refined/tree/main/packages/eslint-plugin-promise#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizunashi-mana/eslint-config-refined.git",
    "directory": "packages/eslint-plugin-promise"
  },
  "bugs": {
    "url": "https://github.com/mizunashi-mana/eslint-config-refined/issues"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "promise",
    "async",
    "await"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "type": "module",
  "imports": {
    "#lib": "./src/lib/index.ts"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "lint:eslint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@mizunashi_mana/eslint-config-refined": "^0.1.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.0",
    "jiti": "^2.6.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.0"
  }
}
