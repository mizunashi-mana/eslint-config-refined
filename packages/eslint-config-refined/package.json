{
  "name": "@mizunashi_mana/eslint-config-refined",
  "version": "1.0.0",
  "description": "A refined, opinionated ESLint shared configuration",
  "license": "(Apache-2.0 OR MPL-2.0)",
  "author": "mizunashi-mana",
  "homepage": "https://github.com/mizunashi-mana/eslint-config-refined/tree/main/packages/eslint-config-refined#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizunashi-mana/eslint-config-refined.git",
    "directory": "packages/eslint-config-refined"
  },
  "bugs": {
    "url": "https://github.com/mizunashi-mana/eslint-config-refined/issues"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "typescript",
    "stylistic",
    "opinionated"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "lint:eslint": "eslint --cache .",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.0",
    "@mizunashi_mana/eslint-plugin-promise": "^1.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-react-x": "^3.0.0",
    "eslint-plugin-storybook": "^10.3.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.0.0",
    "jiti": "^2.6.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
